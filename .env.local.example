# ============================================================
# 환경변수 설정 가이드
# 이 파일을 복사하여 .env.local 로 저장하고 실제 값을 입력하세요
# cp .env.local.example .env.local
# ============================================================

# ── Firebase (problems · lexile_test_results) ───────────────
# Firebase Console: https://console.firebase.google.com
# 프로젝트 설정 → 웹 앱 → SDK 설정 및 구성에서 확인
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ── Turso (메인 지식 DB) ────────────────────────────────────
# Turso 대시보드: https://app.turso.tech
# 1. DB 생성: turso db create korea-english-solution
# 2. URL 확인: turso db show korea-english-solution
# 3. 토큰 발급: turso db tokens create korea-english-solution
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Anthropic Claude API ────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key

# ── Google Gemini API (미래 사용 예정) ───────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Vercel Blob (이미지·파일 · 기존) ───────────────────────
# BLOB_READ_WRITE_TOKEN=vercel_blob_your-token
