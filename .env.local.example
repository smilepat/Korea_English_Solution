# ============================================================
# 환경변수 설정 가이드
# 이 파일을 복사하여 .env.local 로 저장하고 실제 값을 입력하세요:
#   cp .env.local.example .env.local
#
# ⚠️ Firebase·Anthropic 은 더 이상 쓰지 않습니다(Turso + Gemini 단일화).
# ============================================================

# ── Turso (유일한 DB: 학생·진단·과제·콘텐츠 전부) ───────────
# ⚠️ 이 DB 는 `connectedu` org 소속입니다. 토큰 발급 시 org 전환 필요:
#   turso db tokens create korea-english-solution-2026   (connectedu org 로그인 상태)
#   turso db show korea-english-solution-2026            (URL 확인)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Google Gemini (모든 AI: 생성·채점·임베딩) ───────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# 모델 교체 시에만 설정(기본 gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
